# ─── Required ─────────────────────────────────────────────────────────────────
# Google AI API key (get from https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_api_key_here

# ─── Model Configuration (optional — defaults shown) ─────────────────────────
# LLM_MODEL=models/gemini-3.1-flash-lite-preview
# EMBEDDING_MODEL=models/gemini-embedding-001

# ─── ChromaDB (optional — defaults shown) ─────────────────────────────────────
# CHROMA_PERSIST_DIR=./chroma_db
# CHROMA_COLLECTION_NAME=hdfc_funds

# ─── Retrieval (optional — defaults shown) ────────────────────────────────────
# VECTOR_SEARCH_K=3
# BM25_SEARCH_K=3

# ─── Chunking (optional — defaults shown) ─────────────────────────────────────
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100

# ─── API Server (optional — defaults shown) ───────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8001
